{
  "expo": {
    "name": "Diálogos",
    "slug": "dialogos",
    "version": "1.3.25",
    "platforms": [
      "web",
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDB640"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unicesumar.projeto.dialogos",
      "infoPlist": {
        "NSCameraUsageDescription": "Este app usa a câmera para leitura de QR Codes.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "buildNumber": "5"
    },
    "android": {
      "package": "com.unicesumar.projeto.dialogos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json",
      "versionCode": 4
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "64bf8404-64b0-4f83-a9d4-1a7f85749026"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Este app usa a câmera para leitura de QR Codes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0B102F",
          "sounds": []
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/64bf8404-64b0-4f83-a9d4-1a7f85749026"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
